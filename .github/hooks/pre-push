#!/bin/sh
# Pre-push hook to prevent accidental pushes to main

protected_branch="main"
current_branch=$(git symbolic-ref HEAD | sed -e 's,.*/\(.*\),\1,')

if [ "$current_branch" = "$protected_branch" ]; then
    echo ""
    echo "⚠️  WARNING: You are about to push to the '$protected_branch' branch!"
    echo "   This will deploy directly to PRODUCTION."
    echo ""
    echo "   Recommended workflow:"
    echo "   1. Create a feature branch: git checkout -b feature/your-change"
    echo "   2. Push the branch: git push origin feature/your-change"
    echo "   3. Create a Pull Request on GitHub"
    echo "   4. Merge PR to deploy"
    echo ""
    read -p "Are you sure you want to push to main? (yes/no): " confirm
    if [ "$confirm" != "yes" ]; then
        echo "Push cancelled."
        exit 1
    fi
fi

exit 0
