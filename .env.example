# Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# LOCAL DEVELOPMENT (dev.bat)
# ==========================================
# These are used when running locally with npm run dev
VITE_API_URL=http://localhost:8787

# ==========================================
# DEV/STAGING ENVIRONMENT
# ==========================================
# Deployed automatically when pushing to 'develop' branch
# DEV_URL=https://dev.magicbox.bankapirak.com
# DEV_API_URL=https://api-dev.magicbox.bankapirak.com

# ==========================================
# PRODUCTION ENVIRONMENT  
# ==========================================
# Deployed when you manually trigger or merge to 'main'
# PROD_URL=https://magicbox.bankapirak.com
# PROD_API_URL=https://api.magicbox.bankapirak.com

# ==========================================
# CLOUDFLARE (Required for all deployments)
# ==========================================
# Get from: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Cloudflare Workers, Pages, D1
# CLOUDFLARE_API_TOKEN=your_token_here
# CLOUDFLARE_ACCOUNT_ID=49b16ed3ff0d8209f2a3da300341283b
